rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function myTier() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/registrar/main).data.tier;
    }
    function isInstructorOrArchon() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/registrar/main) &&
        (myTier() == "INSTRUCTOR" || myTier() == "ARCHON");
    }
    function isArchon() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/registrar/main) &&
        myTier() == "ARCHON";
    }

    // ─── User-private space ───────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Registrar: write-once identity, tier/certificate fields may be appended.
    match /users/{uid}/registrar/{doc} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isArchon());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.cosmologicalId == resource.data.cosmologicalId
        && request.resource.data.ledgerSeed == resource.data.ledgerSeed
        && request.resource.data.geoVector == resource.data.geoVector;
      allow delete: if false;
    }

    // Transactions: owner write (award/purchase), owner read only
    match /users/{uid}/transactions/{txId} {
      allow read:   if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if false;
    }

    // Inventory: owner read/write, no deletes
    match /users/{uid}/inventory/{itemId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Codex and other per-user subcollections: owner-only
    match /users/{uid}/{collection}/{doc=**} {
      allow read, write: if isSignedIn() && request.auth.uid == uid
        && collection != "registrar"
        && collection != "transactions"
        && collection != "inventory";
    }

    // ─── Tomes ────────────────────────────────────────────────────────
    function isViewCountOnlyUpdate() {
      let allowed = ['viewCount', 'updatedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }
    function isStampUpdate() {
      let allowed = ['stampCount', 'stampedBy', 'updatedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }
    function isCertificationUpdate() {
      // Only Instructors/Archons may write certification fields
      let certFields = ['owlCertified','owlCertifiedBy','owlCertifiedAt',
                        'deptCertified','deptCertifiedBy','deptCertifiedAt','deptCertifiedPlane',
                        'updatedAt'];
      return isInstructorOrArchon() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(certFields);
    }
    match /tomes/{tomeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isSignedIn() && (
        isViewCountOnlyUpdate()
        || isStampUpdate()
        || isCertificationUpdate()
        || resource.data.creatorUid == request.auth.uid
        || isInstructorOrArchon()
      );
      allow delete: if isSignedIn()
        && (resource.data.creatorUid == request.auth.uid || isArchon());
    }

    // ─── Artifacts ────────────────────────────────────────────────────
    match /artifacts/{artifactId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.creatorUid == request.auth.uid
        && isInstructorOrArchon();
      allow update: if isSignedIn()
        && (resource.data.creatorUid == request.auth.uid || isInstructorOrArchon());
      allow delete: if isArchon();
    }

    // ─── Tome Seal System ─────────────────────────────────────────────
    // Minor tomes live at users/{uid}/minorTomes/* (owner-only via the per-user
    // catch-all above) and hold the ECDSA private key. These are the shared
    // surfaces that make seals verifiable and unlocks auditable.

    // Public seal registry — verification surface only; never holds a private key.
    match /seals/{sealId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Owner may only flip lifecycle status (recall / archive) — content frozen.
      allow update: if isSignedIn() && resource.data.ownerUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','updatedAt','recalledTick']);
      allow delete: if false; // recall via status, never delete — preserves traceability
    }

    // Major Tomes — centralized immutable canon. Archons inscribe; no edits/deletes.
    match /majorTomes/{tomeId} {
      allow read:   if isSignedIn();
      allow create: if isArchon() && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Unlock requests — a student asks for access, signed by their minor tome.
    match /unlockRequests/{reqId} {
      allow read:   if isSignedIn() && (resource.data.studentUid == request.auth.uid || isInstructorOrArchon());
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      // Instructors/Archons resolve the request (status fields only).
      allow update: if isInstructorOrArchon()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','resolvedBy','resolvedAt','grantId','updatedAt']);
      allow delete: if false;
    }

    // Unlock grants — the combined student×instructor seal. Immutable record.
    match /tomeUnlocks/{grantId} {
      allow read:   if isSignedIn();
      allow create: if isInstructorOrArchon() && request.resource.data.issuerUid == request.auth.uid;
      // Only an Archon may revoke (status fields only); otherwise frozen.
      allow update: if isArchon()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','revokedBy','revokedAt','updatedAt']);
      allow delete: if false;
    }

    // ─── Chronicle (audit log, server-side reads only) ────────────────
    match /chronicles/{entry} {
      allow create: if isSignedIn();
      allow read:   if false;
    }

    // ─── Constellation Map (public genesis positions) ─────────────────
    match /constellations/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ─── Guilds ───────────────────────────────────────────────────────
    match /guilds/{guildId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        get(/databases/$(database)/documents/guilds/$(guildId)).data.members.hasAny([request.auth.uid]);
    }
    match /guilds/{guildId}/chronicle/{entry} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() &&
        get(/databases/$(database)/documents/guilds/$(guildId)).data.members.hasAny([request.auth.uid]);
    }
  }
}
