rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data — except the Registrar, which is write-once.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Registrar: cosmologicalId and ledgerSeed are write-once. Tier-upgrade
    // updates are permitted but must preserve the core identity fields.
    match /users/{uid}/registrar/{doc} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.cosmologicalId == resource.data.cosmologicalId
        && request.resource.data.ledgerSeed == resource.data.ledgerSeed
        && request.resource.data.geoVector == resource.data.geoVector;
      allow delete: if false;
    }

    // Codex and everything else under /users/{uid}/ is freely mutable by owner
    match /users/{uid}/{collection}/{doc=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid
        && collection != "registrar";
    }

    // Tomes: globally readable, creator-owned writes
    match /tomes/{tomeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.creatorUid == request.auth.uid;
    }

    // Artifacts: same pattern as tomes
    match /artifacts/{artifactId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.creatorUid == request.auth.uid;
    }

    // Chronicle is write-only for authenticated users, read by none (server-side only)
    match /chronicles/{entry} {
      allow create: if request.auth != null;
      allow read:   if false;
    }

    // Guilds: any authenticated user can read, only members can write
    match /guilds/{guildId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/guilds/$(guildId)).data.members.hasAny([request.auth.uid]);
    }

    match /guilds/{guildId}/chronicle/{entry} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/guilds/$(guildId)).data.members.hasAny([request.auth.uid]);
    }
  }
}
